{
  "name": "context-accordion",
  "version": "0.1.0",
  "description": "Token-efficient, layered context delivery for AI agents. Context is always available — just collapsed by default.",
  "author": "Harbor Office",
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "context",
    "llm",
    "prompt-engineering",
    "rag",
    "token-efficiency",
    "context-window",
    "orchestration"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ai-sdk": {
      "types": "./dist/adapters/ai-sdk.d.ts",
      "import": "./dist/adapters/ai-sdk.mjs",
      "require": "./dist/adapters/ai-sdk.js"
    },
    "./langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "import": "./dist/adapters/langchain.mjs",
      "require": "./dist/adapters/langchain.js"
    },
    "./distill": {
      "types": "./dist/distill/index.d.ts",
      "import": "./dist/distill/index.mjs",
      "require": "./dist/distill/index.js"
    },
    "./embeddings": {
      "types": "./dist/embeddings/index.d.ts",
      "import": "./dist/embeddings/index.mjs",
      "require": "./dist/embeddings/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "@qdrant/js-client-rest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@qdrant/js-client-rest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@qdrant/js-client-rest": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harbor-office/context-accordion.git"
  },
  "homepage": "https://github.com/harbor-office/context-accordion#readme",
  "bugs": {
    "url": "https://github.com/harbor-office/context-accordion/issues"
  }
}
